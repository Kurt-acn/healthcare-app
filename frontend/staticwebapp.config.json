{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/*.js",
      "/*.mjs",
      "/*.css",
      "/*.png",
      "/*.jpg",
      "/*.ico",
      "/*.svg",
      "/*.woff",
      "/*.woff2",
      "/*.ttf",
      "/*.eot",
      "/*.json",
      "/*.webmanifest"
    ]
  },
  "mimeTypes": {
    ".js": "application/javascript",
    ".mjs": "application/javascript"
  }
}